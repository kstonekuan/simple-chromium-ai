{
	"manifest_version": 3,
	"name": "Chrome AI Demo",
	"version": "1.0",
	"description": "Minimal Chrome AI demo",
	"permissions": ["sidePanel"],
	"side_panel": {
		"default_path": "popup.html"
	},
	"action": {
		"default_title": "Open Chrome AI Demo"
	},
	"background": {
		"service_worker": "background.js"
	}
}
